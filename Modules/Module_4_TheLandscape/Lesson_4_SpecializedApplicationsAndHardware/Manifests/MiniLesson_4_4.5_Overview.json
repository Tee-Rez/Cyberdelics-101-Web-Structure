                "questions": [
                    {
                        "question": "<h3>The Soundself Mechanism</h3><p>What mechanism makes Soundself different from a music playlist for altering states?</p>",
                        "options": [
                            {
                                "id": "q1_a",
                                "label": "Special brainwave frequencies",
                                "correct": false
                            },
                            {
                                "id": "q1_b",
                                "label": "Higher audio quality",
                                "correct": false
                            },
                            {
                                "id": "q1_c",
                                "label": "Designed for psychedelics",
                                "correct": false
                            },
                            {
                                "id": "q1_d",
                                "label": "Active vocal feedback loop",
                                "correct": true
                            }
                        ],
                        "synthesis": {
                            "q1_a": "<p>Many apps use frequencies. That's not the unique mechanism.</p>",
                            "q1_b": "<p>Quality matters, but doesn't change the *interaction*.</p>",
                            "q1_c": "<p>It's a technology-based alternative, not a companion.</p>",
                            "q1_d": "<p><strong>Correct!</strong> It creates a 'technodelic loop' where your own voice generates the environment in real-time. You are an active participant, not a passive listener.</p>"
                        }
                    },
                    {
                        "question": "<h3>Group Facilitation</h3><p>A facilitator wants to lead a synchronized group breathwork session for 8 people with visual pacing. Which platform is best?</p>",
                        "options": [
                            {
                                "id": "q2_a",
                                "label": "Soundself",
                                "correct": false
                            },
                            {
                                "id": "q2_b",
                                "label": "TRIPP",
                                "correct": false
                            },
                            {
                                "id": "q2_c",
                                "label": "Othership",
                                "correct": true
                            },
                            {
                                "id": "q2_d",
                                "label": "Wavepaths",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q2_a": "<p>Soundself is for individual vocalization, not group breathing.</p>",
                            "q2_b": "<p>Wavepaths provides music, not visual breath pacing.</p>",
                            "q2_c": "<p><strong>Correct!</strong> Othership is specifically designed for group facilitation, offering synchronized sessions with clear visual pacing for everyone.</p>",
                            "q2_d": "<p>TRIPP is primarily for solo wellness.</p>"
                        }
                    },
                    {
                        "question": "<h3>Flow Conditions</h3><p>What helps physical VR movement produce flow state rather than just exercise fatigue?</p>",
                        "options": [
                            {
                                "id": "q1_a",
                                "label": "Long duration (45+ mins)",
                                "correct": false
                            },
                            {
                                "id": "q1_b",
                                "label": "High intensity (burning calories)",
                                "correct": false
                            },
                            {
                                "id": "q1_c",
                                "label": "Social competition",
                                "correct": false
                            },
                            {
                                "id": "q1_d",
                                "label": "Clear goals + Challenge-skill balance",
                                "correct": true
                            }
                        ],
                        "synthesis": {
                            "q1_a": "Intensity without balance creates anxiety or exhaustion.",
                            "q1_b": "Flow happens in minutes if conditions are right.",
                            "q1_c": "Competition can help some, but isn't a requirement.",
                            "q1_d": "<strong>Correct!</strong> When the challenge matches your skill and feedback is immediate, action merges with awareness."
                        }
                    },
                    {
                        "question": "<h3>Agoraphobia Access</h3><p>A client with severe agoraphobia wants to practice being in open environments but cannot leave home. What is the best recommendation?</p>",
                        "options": [
                            {
                                "id": "q2_a",
                                "label": "Nature Treks VR (exposure)",
                                "correct": true
                            },
                            {
                                "id": "q2_b",
                                "label": "Supernatural (distraction)",
                                "correct": false
                            },
                            {
                                "id": "q2_c",
                                "label": "Wait for therapy progress",
                                "correct": false
                            },
                            {
                                "id": "q2_d",
                                "label": "VRChat (social support)",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q2_a": "<p><strong>Correct!</strong> It provides a safe, graded way to experience open spaces (70% effective restoration) without triggering the full panic of leaving home.</p>",
                            "q2_b": "Distraction avoids the issue. Exposure engages it.",
                            "q2_c": "VR *is* a valid therapeutic step, significantly better than total isolation.",
                            "q2_d": "Social support doesn't address the specific environment fear."
                        }
                    },
                    {
                        "question": "<h3>Riva Research (2025)</h3><p>What did the Milan study demonstrate about experimental VR?</p>",
                        "options": [
                            {
                                "id": "q1_a",
                                "label": "It produces comparable short-term effects (insight, catharsis).",
                                "correct": true
                            },
                            {
                                "id": "q1_b",
                                "label": "It replaces psychedelics perfectly.",
                                "correct": false
                            },
                            {
                                "id": "q1_c",
                                "label": "It is safe for everyone without prep.",
                                "correct": false
                            },
                            {
                                "id": "q1_d",
                                "label": "It only works in Italy.",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q1_a": "<p><strong>Correct!</strong> It validated that VR can induce states functionally similar to LSD/psilocybin in key dimensions.</p>",
                            "q1_b": "It's comparable, not identical.",
                            "q1_c": "Intensity creates *more* need for prep."
                        }
                    },
                    {
                        "question": "<h3>Ethical Obligation</h3><p>Which is <strong>NOT</strong> an ethical requirement for high-intensity facilitation?</p>",
