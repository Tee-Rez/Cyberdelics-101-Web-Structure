                            {
                                "id": "q2_b",
                                "label": "Integration support",
                                "correct": false
                            },
                            {
                                "id": "q2_c",
                                "label": "Legal liability waiver",
                                "correct": true
                            },
                            {
                                "id": "q2_d",
                                "label": "Psychological screening",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q2_a": "Required for safety.",
                            "q2_b": "Required for meaning-making.",
                            "q2_d": "Required to filter contraindications.",
                            "q2_c": "<strong>Correct!</strong> Waivers are a legal/business protection, not an ethical care requirement. Facilitators minimize harm, lawyers minimize liability."
                        }
                    },
                    {
