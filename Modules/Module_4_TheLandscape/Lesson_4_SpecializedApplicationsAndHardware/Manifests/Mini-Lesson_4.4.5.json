                "questions": [
                    {
                        "question": "<h3>The Comfort vs. Budget Trade-off</h3><p>Client wants to do 60-minute sessions and can afford ~$500. They have no gaming PC. Why recommend Quest 3 over Quest 3S?</p>",
                        "options": [
                            {
                                "id": "q1_a",
                                "label": "Quest 3S runs fewer apps.",
                                "correct": false
                            },
                            {
                                "id": "q1_b",
                                "label": "Quest 3 has significantly better comfort/optics for long wear.",
                                "correct": true
                            },
                            {
                                "id": "q1_c",
                                "label": "Quest 3S requires a PC.",
                                "correct": false
                            },
                            {
                                "id": "q1_d",
                                "label": "Quest 3 tracks more biofeedback.",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q1_a": "They run the same library.",
                            "q1_c": "Both are standalone.",
                            "q1_b": "<strong>Correct!</strong> For 60-minute sessions, the front-heavy Quest 3S becomes painful. Pancake lenses and balance justify the cost."
                        }
                    },
                    {
                        "question": "<h3>The Hierarchy of Needs</h3><p>What is the single most important factor to verify first?</p>",
                        "options": [
                            {
                                "id": "q2_a",
                                "label": "Display Resolution",
                                "correct": false
                            },
                            {
                                "id": "q2_b",
                                "label": "Content Compatibility",
                                "correct": true
                            },
                            {
                                "id": "q2_c",
                                "label": "Release Date",
                                "correct": false
                            },
                            {
                                "id": "q2_d",
                                "label": "Field of View",
                                "correct": false
                            }
                        ],
                        "synthesis": {
                            "q2_a": "Useless if the app doesn't run.",
                            "q2_c": "Newer isn't always better for specific apps.",
                            "q2_b": "<strong>Correct!</strong> Hardware is a vehicle for software. If it can't run TRIPP/Maloka, it fails the mission regardless of specs."
                        }
                    }
                ]
            }
